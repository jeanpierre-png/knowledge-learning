{% extends 'base.html.twig' %}

{% block title %}{{ course.title }}{% endblock %}

{% block body %}

<div class="container">

    <h1>{{ course.title }}</h1>

    <div class="card">
        <p>Prix : {{ course.price }} €</p>

        {% if coursePurchased %}
            <p class="success">Vous possédez déjà ce cursus.</p>

        {% else %}

            <a class="btn btn-buy" href="{{ path('app_stripe_course', { id: course.id }) }}" >Acheter le cursus</a>

        {% endif %}
            
    </div>

    <h2>Leçons</h2>

    <div class="lesson-list">
    
        {% for lesson in course.lessons %}

            <div class="lesson-item">

                <div>

                    <strong>{{ lesson.title }}</strong><br>
                    <span class="price">{{ lesson.price }} €</span>

                </div>

                <div>
                    {% if coursePurchased or (lessonPurchases[lesson.id] is defined and lessonPurchases[lesson.id]) %}
                        <a href="{{ path('app_lesson', { id: lesson.id }) }}">Voir la leçon</a>

                    {% else %}  

                        <a href="{{ path('app_stripe_lesson', { id: lesson.id }) }}">Acheter cette leçon</a>

                    {% endif %}   
                </div>
   
            
            </div>

        {% else %}

            <p>Acune leçon disponible.</p>

        {% endfor %}

    </div>

    <a href="{{ path('app_theme', { id: course.theme.id }) }}">
        Retour au thème
    </a>

</div>

{% endblock %}
