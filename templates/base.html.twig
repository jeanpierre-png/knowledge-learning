<!DOCTYPE html>

<html>

    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Knowledge Learning{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/favicon.png')}}">
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/theme.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/course.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/lesson.css') }}">
    </head>

    <body>

        <header class="header">

            <div class="logo">
                <img src="{{ asset('logo/Logo.jpeg') }}" alt="Logo Knowledge Learning">
                <p>Apprendre en toute autonomie</p>
            </div>


            <nav>

                <a class="{%if app.request.attributes.get('_route') == 'app_home' %}active-link{% endif %}"
                    href="{{ path('app_home') }}">
                    Accueil
                </a>

                {% if app.user %}
                    <a href="#">Mes formations</a>
                    <a href="#">Mes certifications</a>

                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="#">Back-office</a>
                    {% endif %}

                    <a href="{{ path('app_logout')}}">Se déconnecter</a>
                {% else %}

                    <a  class="{% if app.request.attributes.get('_route') == 'app_register' %}active-link{% endif %}"  
                        href="{{ path('app_register') }}"
                    >
                        S'inscrire
                    </a>
                    <a  class="{% if app.request.attributes.get('_route') == 'app_login' %}active-link{% endif %}"  
                        href="{{ path('app_login') }}"
                    >
                        Se connecter
                    </a>
                {% endif %}
            </nav>
        </header>
        

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="footer">
            <p> Knowledge Learning - Plateforme e-learning</p>
        </footer>
    </body>
</html>
