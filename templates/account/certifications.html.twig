{% extends 'base.html.twig' %}

{% block title %}Mes Certifications{% endblock %}

{% block body %}

<h1>Mes certifications</h1>

{% for certification in certifications %}

    <div class="card">

        <h2>{{ certification.course.title }}</h2>

        <p>Obtenue le : {{ certification.obtainedAt|date('d/m/Y H:i') }}</p>

    </div>

{% else %}
   
    <p>Vous n'avez encore obtenu aucune certification.</p>

{% endfor %}

{% endblock %}
